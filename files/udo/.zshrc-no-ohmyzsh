# AUTO COMPLETION
# ---------------

autoload -U compinit; compinit
# autoload: Zsh command that loads a function or file only when it is first needed (lazily), rather than loading it immediately
# -U: This option tells autoload to unconditionally load the function, even if it's already been loaded previously.
# compinit: built-in function in Zsh that initializes the completion system

# Add more completions to search path
if [[ ":${FPATH}:" != *":/home/${USER}/.zsh/completions:"* ]]; then
	export FPATH="/home/${USER}/.zsh/completions:${FPATH}";
fi

# SHELL OPTIONS
# -------------

# man zshoptions
setopt extended_glob
setopt no_nomatch # prevents zsh: no matches found

# WORD NAVIGATION
# ---------------

WORDCHARS='*?_-.[]~=&;!#$%^(){}<>/ '$'\n'
autoload -Uz select-word-style
select-word-style normal
zstyle ':zle:*' word-style unspecified

# KEY BINDINGS
# ------------

bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word
bindkey "^[[3;5~" kill-word

# Home and End 
bindkey "\e[H" beginning-of-line
bindkey "\e[F" end-of-line

# ENV
# ---

# first source bash_env
if [[ -f "${HOME}/.bash_env" ]]; then
	source "${HOME}/.bash_env"
else
	# .bash_env is missing add some basic env settings:
	if [[ -d "${HOME}/.local/bin" ]] && [[ "${PATH}" != *":${HOME}/.local/bin:"* ]] ; then
    	PATH="${HOME}/.local/bin:${PATH}"
	fi

	export EDITOR=nano
fi

# OTHER SETTINGS
# --------------

# export MANPATH="/usr/local/man:$MANPATH"
# You may need to manually set your language environment
# export LANG=en_US.UTF-8
# Compilation flags
# export ARCHFLAGS="-arch $(uname -m)"

# Uncomment the following line if pasting URLs and other text is messed up.
# DISABLE_MAGIC_FUNCTIONS="true"

DISABLE_AUTO_TITLE="false"
ENABLE_CORRECTION="false"

# COMPLETION_WAITING_DOTS="%F{yellow}waiting...%f"
# Caution: this setting can cause issues with multiline prompts in zsh < 5.7.1 (see #5765)
# COMPLETION_WAITING_DOTS="true"

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# You can set one of the optional three formats:
# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# or set a custom format using the strftime function format specifications,
# see 'man strftime' for details.
# HIST_STAMPS="mm/dd/yyyy"

# PROMPT
# ------

# PROMPT='%F{green}%n@%m%f %F{blue}%~ %# '
# PROMPT="%F{42}%n%f@%F{42}%m%f:%F{36}%~%f: "
PROMPT="%F{42}%n%f@%F{42}%m%f:%F{36}%~%f 〉"

# HISTORY
# -------

export HISTFILE=$HOME/.zsh_history

if [[ ! -f "${HISTFILE}" ]]; then
	touch $HISTFILE
	chmod 600 $HISTFILE
fi

# Maximum lines kept in memory
export HISTSIZE=100000
# Maximum lines saved to $HISTFILE
export SAVEHIST=100000
# Like INC_APPEND_HISTORY + re-read history whenever accessing it
setopt SHARE_HISTORY

# PLUGINS
# -------

# fuzzy completion
if [[ -f "/usr/bin/fzf" ]]; then
	source <(fzf --zsh)
fi
# zsh-syntax-highlighting
if [[ -f "/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
	source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
# zsh-autosuggestions
if [[ -f "/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
	source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
